# ─────────────────────────────────────────────
# Weather Alert System – Environment Variables
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# ── LLM Provider (choose ONE option below) ────────────────────────────

# ⬇ OPTION 1 — Ollama (LOCAL, 100% FREE, recommended)
#   Install: https://ollama.com   then run: ollama pull qwen2.5:7b
#   Supports: Hindi, Marathi, Telugu, Kannada, Punjabi, etc. out of the box
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b
# Other good free models: gemma3:9b  |  llama3.2:3b (lighter)  |  aya-expanse:8b

# ⬇ OPTION 2 — Google Gemini free tier (cloud, 15 req/min free)
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=<your_gemini_api_key>   # free at https://aistudio.google.com
# LLM_MODEL=gemini-2.0-flash

# ⬇ OPTION 3 — OpenAI (paid)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# ── Twilio (SMS / WhatsApp) ──
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_SMS_FROM=+1XXXXXXXXXX           # Twilio phone number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # Twilio sandbox / approved WA number

# ── Email (SMTP – optional fallback) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=app-password-here
EMAIL_FROM=WeatherAlert <your@gmail.com>

# ── data.gov.in Crop Data API (optional, free) ────────────────────
# Register FREE at https://data.gov.in/user/register → My Account → API Key
# Without this, a built-in crop calendar is used (works for all 80+ districts)
DATA_GOV_IN_API_KEY=

ALERT_HOUR=11          # 11 AM IST daily dispatch
ALERT_MINUTE=0
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///data/farmers.db

# ── Open-Meteo (free, no key required) ──
# OPEN_METEO_BASE_URL is set in config/settings.py

# ── IMD endpoints ──
# IMD_CAP_RSS_URL is set in config/settings.py
